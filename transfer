        logger.info(
            f"Function triggered by message ID: {getattr(context, 'event_id', 'unknown')}")
        logger.info(
            f"Function execution timestamp: {getattr(context, 'timestamp', 'unknown')}")

        # Early timeout check
        elapsed = check_timeout()
        logger.info(f"⏱️ Execution time check: {elapsed:.2f}s elapsed")

        # Decode the Pub/Sub message
        if 'data' not in data:
            error_msg = "No data field in Pub/Sub message"
            logger.error(error_msg)
            log_error_context(execution_id, 'unknown', 'pubsub_message_decode',
                              ValueError(error_msg), {'pubsub_data_keys': list(data.keys())})
            return "ERROR: No data field"

        # Base64 decode the message
        decode_start = datetime.utcnow()
        message_data = base64.b64decode(data['data']).decode('utf-8')
        log_entry = json.loads(message_data)
        decode_time_ms = (datetime.utcnow() -
                          decode_start).total_seconds() * 1000
        log_performance_metrics('decode_pubsub_message', decode_time_ms)

        # Check timeout after decode
        elapsed = check_timeout()

        logger.info(f"📨 LOG ENTRY RECEIVED", extra={
            'execution_id': execution_id,
            'action': 'LOG_ENTRY_DECODED',
            'elapsed_seconds': elapsed
        })
        logger.info(
            f"Received log entry: {log_entry.get('logName', 'unknown')}")

        # Extract relevant information from the log entry
        extract_start = datetime.utcnow()
        resource_info = extract_resource_info(log_entry)
        if not resource_info:
            error_msg = "Could not extract resource information from log entry"
            logger.warning(error_msg)
            log_error_context(execution_id, 'unknown', 'resource_info_extraction',
                              ValueError(error_msg), {'log_entry_keys': list(log_entry.keys())})
            return "SKIPPED: Unable to extract resource info"

        extract_time_ms = (datetime.utcnow() -
                           extract_start).total_seconds() * 1000
        log_performance_metrics('extract_resource_info',
                                extract_time_ms, resource_info['resource_name'])

        # Check timeout after resource extraction
        elapsed = check_timeout()

        logger.info(f"🎯 RESOURCE IDENTIFIED", extra={
            'execution_id': execution_id,
            'resource_name': resource_info['resource_name'],
            'resource_type': resource_info['resource_type'],
            'action': 'RESOURCE_IDENTIFIED',
            'elapsed_seconds': elapsed
        })

        # Check if this is an IAM policy change we should process
        if not should_process_change(log_entry, resource_info):
            result['action'] = 'SKIPPED_CRITERIA_NOT_MET'
            logger.info(f"⏭️ PROCESSING SKIPPED", extra={
                'execution_id': execution_id,
                'resource_name': resource_info['resource_name'],
                'action': 'PROCESSING_SKIPPED'
            })
            return "SKIPPED: Does not meet criteria"

        # Final timeout check before processing
        elapsed = check_timeout()
        logger.info(
            f"⏱️ Starting remediation with {execution_timeout - elapsed:.2f}s remaining")

        # Add execution_id to result for tracking
        result['execution_id'] = execution_id

        # Process the IAM change with performance tracking
        process_start = datetime.utcnow()
        result = handle_iam_change(log_entry, resource_info)
        # Ensure execution_id is preserved
        result['execution_id'] = execution_id
        process_time_ms = (datetime.utcnow() -
                           process_start).total_seconds() * 1000
        log_performance_metrics(
            'handle_iam_change', process_time_ms, resource_info['resource_name'])

        # Log comprehensive remediation action
        log_remediation_action(log_entry, resource_info, result)

        # Store audit record if BigQuery is enabled
        if BIGQUERY_DATASET and BIGQUERY_TABLE:
            audit_start = datetime.utcnow()
            store_audit_record(log_entry, resource_info, result)
            audit_time_ms = (datetime.utcnow() -
                             audit_start).total_seconds() * 1000
            log_performance_metrics(
                'store_audit_record', audit_time_ms, resource_info['resource_name'])

        # Log overall execution metrics
        total_time_ms = (datetime.utcnow() - start_time).total_seconds() * 1000
        log_performance_metrics(
            'total_execution', total_time_ms, resource_info['resource_name'])

        logger.info(f"✅ OVERWATCH EXECUTION COMPLETED", extra={
            'execution_id': execution_id,
            'resource_name': resource_info['resource_name'],
            'action': 'FUNCTION_COMPLETED'
        })
        logger.info(f"Successfully processed IAM change: {result['action']}")

        return f"SUCCESS: {result['action']}"

    except TimeoutError as e:
        # Handle timeout specifically
        current_time = datetime.utcnow()
        elapsed_time = (current_time - start_time).total_seconds()

        logger.error(f"⏰ EXECUTION TIMEOUT", extra={
            'execution_id': execution_id,
            'resource_name': resource_info.get('resource_name', 'unknown'),
            'action': 'FUNCTION_TIMEOUT',
            'elapsed_seconds': elapsed_time,
            'timeout_limit_seconds': execution_timeout
        })

        # Update result for timeout
        result.update({
            'action': 'EXECUTION_TIMEOUT',
            'error_message': f"Function execution timed out after {elapsed_time:.2f}s",
            'changes_made': False,
            'elapsed_seconds': elapsed_time
        })

        # Still attempt to log the timeout for audit purposes
        try:
            log_remediation_action(log_entry, resource_info, result)
            if BIGQUERY_DATASET and BIGQUERY_TABLE:
                store_audit_record(log_entry, resource_info, result)
        except Exception as audit_error:
            logger.warning(
                f"Failed to log timeout audit record: {audit_error}")

        return f"TIMEOUT: Execution exceeded {execution_timeout}s limit"

    except Exception as e:
        # Log comprehensive error context
        current_time = datetime.utcnow()
        elapsed_time = (current_time - start_time).total_seconds()

        log_error_context(execution_id, resource_info.get('resource_name', 'unknown'),
                          'process_iam_change', e, {
            'pubsub_message_keys': list(data.keys()) if data else [],
            'log_entry_available': bool(log_entry),
            'resource_info_available': bool(resource_info),
            'elapsed_seconds': elapsed_time,
            'timeout_limit_seconds': execution_timeout
        })

        # Update result for failed execution
        result.update({
            'action': 'EXECUTION_FAILED',
            'error_message': str(e),
            'changes_made': False,
            'elapsed_seconds': elapsed_time
        })

        # Still log the action and store audit record for failed executions
        try:
            log_remediation_action(log_entry, resource_info, result)
            if BIGQUERY_DATASET and BIGQUERY_TABLE:
                store_audit_record(log_entry, resource_info, result)

            # Log overall execution metrics (failed)
            total_time_ms = (datetime.utcnow() -
                             start_time).total_seconds() * 1000
            log_performance_metrics('total_execution_failed', total_time_ms, resource_info.get(
                'resource_name', 'unknown'))
        except Exception as audit_error:
            logger.warning(f"Failed to log error audit record: {audit_error}")

        logger.error(f"❌ OVERWATCH EXECUTION FAILED", extra={
            'execution_id': execution_id,
            'resource_name': resource_info.get('resource_name', 'unknown'),
            'action': 'FUNCTION_FAILED',
            'elapsed_seconds': elapsed_time
        })
        logger.error(f"Error processing IAM change: {str(e)}", exc_info=True)

        return f"ERROR: {str(e)}"


def extract_resource_info(log_entry: Dict[str, Any]) -> Optional[Dict[str, str]]:
    """
    Extract resource information from the cloud audit log entry.

    Args:
        log_entry: The cloud audit log entry

    Returns:
        Dict containing resource name and type, or None if extraction fails
    """
    try:
        # Extract from protoPayload
        proto_payload = log_entry.get('protoPayload', {})

        # Get resource name from different possible locations
        resource_name = (
            proto_payload.get('resourceName') or
            log_entry.get('resource', {}).get('labels', {}).get('resource_name') or
            proto_payload.get('resource', {}).get('resourceName')
        )

        if not resource_name:
            logger.warning("No resource name found in log entry")
            return None

        # Determine resource type based on resource name pattern
        resource_type = determine_resource_type(resource_name)

        # Extract IAM policy changes
        policy_changes = extract_iam_policy_changes(log_entry)

        result = {
            'resource_name': resource_name,
            'resource_type': resource_type,
            'method_name': proto_payload.get('methodName', ''),
            'caller_ip': proto_payload.get('requestMetadata', {}).get('callerIp', ''),
            'user_agent': proto_payload.get('requestMetadata', {}).get('callerSuppliedUserAgent', ''),
            'timestamp': log_entry.get('timestamp', ''),
            'severity': log_entry.get('severity', ''),
            'policy_changes': policy_changes
        }

        logger.info(
            f"Extracted resource info for {resource_name}: {len(policy_changes.get('bindings', []))} bindings found")
        return result

    except Exception as e:
        logger.error(f"Error extracting resource info: {str(e)}")
        return None


def extract_iam_policy_changes(log_entry: Dict[str, Any]) -> Dict[str, Any]:
    """
    Extract IAM policy changes from the log entry.

    Parses the SetIamPolicy request to extract bindings being added/modified.

    Args:
        log_entry: The cloud audit log entry

    Returns:
        Dict containing policy change details including bindings
    """
    try:
        proto_payload = log_entry.get('protoPayload', {})
        request = proto_payload.get('request', {})

        # Extract the new policy being set
        policy = request.get('policy', {})
        bindings = policy.get('bindings', [])

        # Parse each binding to extract principals and roles
        parsed_bindings = []
        for binding in bindings:
            role = binding.get('role', '')
            members = binding.get('members', [])

            # Categorize members by type
            individual_emails = []
            group_emails = []
            service_accounts = []
            other_principals = []

            for member in members:
                member_type, principal = parse_principal(member)
                if member_type == 'user':
                    individual_emails.append(principal)
                elif member_type == 'group':
                    group_emails.append(principal)
                elif member_type == 'serviceAccount':
                    service_accounts.append(principal)
                else:
                    other_principals.append(member)

            parsed_binding = {
                'role': role,
                'members': members,
                'individual_emails': individual_emails,
                'group_emails': group_emails,
                'service_accounts': service_accounts,
                'other_principals': other_principals
            }

            parsed_bindings.append(parsed_binding)

            logger.debug(
                f"Parsed binding - Role: {role}, Users: {len(individual_emails)}, Groups: {len(group_emails)}, SAs: {len(service_accounts)}")

        # Extract caller information
        authentication_info = proto_payload.get('authenticationInfo', {})
        caller_email = authentication_info.get('principalEmail', '')

        policy_delta = request.get('policyDelta', {})

        return {
            'bindings': parsed_bindings,
            'policy_delta': policy_delta,
            'caller_email': caller_email,
            'total_bindings': len(parsed_bindings),
            'etag': policy.get('etag', ''),
            'version': policy.get('version', 1)
        }

    except Exception as e:
        logger.error(f"Error extracting IAM policy changes: {str(e)}")
        return {
            'bindings': [],
            'policy_delta': {},
            'caller_email': '',
            'total_bindings': 0,
            'etag': '',
            'version': 1
        }


def parse_principal(member: str) -> tuple[str, str]:
    """
    Parse IAM principal to determine type and extract email/identifier.

    Args:
        member: IAM member string (e.g., "user:email@domain.com", "serviceAccount:sa@project.iam.gserviceaccount.com")

    Returns:
        Tuple of (member_type, principal_identifier)
    """
    if ':' not in member:
        return 'unknown', member

    member_type, principal = member.split(':', 1)

    # Map IAM member types
    type_mapping = {
        'user': 'user',
        'group': 'group',
        'serviceAccount': 'serviceAccount',
        'domain': 'domain',
        'deleted': 'deleted',
        'allUsers': 'allUsers',
        'allAuthenticatedUsers': 'allAuthenticatedUsers'
    }

    normalized_type = type_mapping.get(member_type, member_type)

    return normalized_type, principal


def determine_resource_type(resource_name: str) -> str:
    """
    Determine the type of GCP resource based on its name pattern.

    Args:
        resource_name: Full resource name from the log entry

    Returns:
        Resource type string (project, dataset, table, etc.)
    """
    if resource_name.startswith('projects/') and resource_name.count('/') == 1:
        return 'project'
    elif '/datasets/' in resource_name and '/tables/' not in resource_name:
        return 'dataset'
    elif '/datasets/' in resource_name and '/tables/' in resource_name:
        return 'table'
    else:
        # Generic resource type
        parts = resource_name.split('/')
        if len(parts) >= 2:
            return parts[-2].rstrip('s')  # Remove 's' from plural forms
        return 'unknown'


def should_process_change(log_entry: Dict[str, Any], resource_info: Dict[str, str]) -> bool:
    """
    Determine if this IAM change should be processed by Overwatch.

    Args:
        log_entry: The cloud audit log entry
        resource_info: Extracted resource information

    Returns:
        True if the change should be processed
    """
    # Only process SetIamPolicy calls
    if resource_info.get('method_name') != 'SetIamPolicy':
        return False

    # Only process supported resource types
    supported_types = ['project', 'dataset', 'table']
    if resource_info.get('resource_type') not in supported_types:
        return False

    # Check if there are IAM bindings in the request
    proto_payload = log_entry.get('protoPayload', {})
    request = proto_payload.get('request', {})
    policy = request.get('policy', {})
    bindings = policy.get('bindings', [])

    if not bindings:
        logger.info("No IAM bindings found in policy change")
        return False

    return True


