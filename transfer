@with_retry_and_circuit_breaker(
    retry_config=get_optimized_retry_config(),
    circuit_breaker=_bigquery_circuit_breaker
)
def set_dataset_iam_policy(resource_name: str, policy_dict: Dict[str, Any]) -> bool:
    """
    Set IAM policy for a BigQuery dataset with retry logic and comprehensive error handling.

    Args:
        resource_name: Dataset resource name (e.g., projects/project-id/datasets/dataset-id)
        policy_dict: IAM policy as dict

    Returns:
        True if policy was successfully set, False otherwise
    """
    execution_start = time.time()

    try:
        # Parse resource name to extract project and dataset IDs
        parts = resource_name.split('/')
        if len(parts) < 4 or parts[0] != 'projects' or parts[2] != 'datasets':
            logger.error(f"❌ Invalid dataset resource name: {resource_name}")
            return False

        project_id = parts[1]
        dataset_id = parts[3]
        logger.info(
            f"🎯 Applying IAM policy to BigQuery dataset: {project_id}.{dataset_id}")

        # Get BigQuery client
        client = get_bigquery_client()

        # Get dataset reference
        dataset_ref = client.dataset(dataset_id, project=project_id)
        dataset = client.get_dataset(dataset_ref)

        # Store original access entries count for verification
        original_entries_count = len(dataset.access_entries)

        # Clear existing access entries
        dataset.access_entries = []

        # Convert IAM bindings back to BigQuery access entries
        for binding in policy_dict.get('bindings', []):
            role = map_iam_role_to_bigquery(binding['role'])
            members = binding.get('members', [])

            for member in members:
                access_entry = create_bigquery_access_entry(member, role)
                if access_entry:
                    dataset.access_entries.append(access_entry)

        # Update the dataset with timeout awareness
        logger.info(
            f"📝 Executing dataset update for {len(dataset.access_entries)} access entries...")
        client.update_dataset(dataset, ['access_entries'])

        execution_time = (time.time() - execution_start) * 1000
        logger.info(
            f"✅ Successfully applied dataset IAM policy with {len(dataset.access_entries)} access entries in {execution_time:.2f}ms")

        # Log the change for auditability
        logger.info(
            f"📊 Access entries changed: {original_entries_count} → {len(dataset.access_entries)}")

        return True

    except CircuitBreakerError as e:
        execution_time = (time.time() - execution_start) * 1000
        logger.error(
            f"❌ Circuit breaker prevented dataset IAM policy update after {execution_time:.2f}ms: {e}")
        return False
    except Exception as e:
        execution_time = (time.time() - execution_start) * 1000
        error_context = {
            'execution_time_ms': execution_time,
            'project_id': project_id,
            'dataset_id': dataset_id,
            'policy_bindings_count': len(policy_dict.get('bindings', [])),
            'error_type': type(e).__name__,
            'error_message': str(e)
        }

        logger.error(
            f"❌ Error setting dataset IAM policy after {execution_time:.2f}ms: {e}")
        log_error_context(
            f"set_dataset_iam_policy_{project_id}_{dataset_id}", e, error_context)

        # Handle specific BigQuery errors
        if 'NotFound' in str(e):
            logger.error("   Dataset may not exist or may have been deleted")
        elif 'Forbidden' in str(e):
            logger.error(
                "   Insufficient permissions to modify dataset IAM policy")
        elif 'BadRequest' in str(e):
            logger.error(
                "   Invalid policy configuration or malformed access entries")

        return False


