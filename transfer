def create_execution_context(context_id: str = None) -> str:
    """
    Create a unique execution context identifier for tracking operations.

    Args:
        context_id: Optional context identifier from Cloud Function context

    Returns:
        Unique execution identifier
    """
    timestamp = int(datetime.utcnow().timestamp())
    if context_id:
        return f"overwatch_{context_id}_{timestamp}"
    else:
        return f"overwatch_exec_{timestamp}"


