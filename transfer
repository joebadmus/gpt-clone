            'individual_emails_removed': result.get('individual_emails_removed', 0),
            'groups_preserved': result.get('groups_preserved', 0),
            'service_accounts_preserved': result.get('service_accounts_preserved', 0),
            'changes_made': result.get('changes_made', False),
            'details': result.get('details', ''),
            'error_message': result.get('error_message', ''),
            'log_severity': log_entry.get('severity', 'INFO'),
            'function_trigger_id': log_entry.get('insertId', ''),
            'original_log_entry': json.dumps(log_entry)
        }

        # Add analysis details as JSON
        analysis_details = result.get('analysis_details', {})
        if analysis_details:
            audit_record['analysis_summary'] = json.dumps({
                'removal_candidates': analysis_details.get('removal_candidates', []),
                'preserved_groups': analysis_details.get('preserved_groups', []),
                'preserved_service_accounts': analysis_details.get('preserved_service_accounts', [])
            })

        # Add policy comparison as JSON
        policy_comparison = result.get('policy_comparison', {})
        if policy_comparison:
            audit_record['policy_changes_summary'] = json.dumps({
                'new_bindings': policy_comparison.get('new_bindings', 0),
                'modified_bindings': policy_comparison.get('modified_bindings', 0),
                'total_changes': policy_comparison.get('total_changes', 0),
                'new_members': policy_comparison.get('new_members', []),
                'removed_members': policy_comparison.get('removed_members', [])
            })

        # Insert into BigQuery
        client = get_bigquery_client()
        table_id = f"{PROJECT_ID}.{BIGQUERY_DATASET}.{BIGQUERY_TABLE}"

        # Insert the record
        errors = client.insert_rows_json(table_id, [audit_record])

        if errors:
            logger.error(
                f"Failed to insert audit record into BigQuery: {errors}")
            log_error_context(execution_id, resource_info.get('resource_name', ''),
                              'bigquery_audit_insert', Exception(f"BigQuery insert errors: {errors}"))
        else:
            logger.info(f"📊 AUDIT RECORD STORED", extra={
                'execution_id': execution_id,
                'resource_name': resource_info.get('resource_name', ''),
                'action': 'AUDIT_STORED'
            })

    except Exception as e:
        execution_id = result.get('execution_id', 'unknown')
        logger.error(f"Error storing audit record in BigQuery: {str(e)}")
        log_error_context(execution_id, resource_info.get('resource_name', ''),
                          'bigquery_audit_storage', e)


