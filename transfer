class CircuitBreaker:
    """Circuit breaker implementation for API calls"""

    def __init__(self, failure_threshold: int = 5, timeout: float = 60.0):
        self.failure_threshold = failure_threshold
        self.timeout = timeout
        self.failure_count = 0
        self.last_failure_time = None
        self.state = "CLOSED"  # CLOSED, OPEN, HALF_OPEN

    def call(self, func, *args, **kwargs):
        """Execute function through circuit breaker"""
        if self.state == "OPEN":
            if time.time() - self.last_failure_time < self.timeout:
                raise CircuitBreakerError(
                    f"Circuit breaker is OPEN, failing fast")
            else:
                self.state = "HALF_OPEN"

        try:
            result = func(*args, **kwargs)
            if self.state == "HALF_OPEN":
                self.state = "CLOSED"
                self.failure_count = 0
            return result
        except Exception as e:
            self.failure_count += 1
            self.last_failure_time = time.time()

            if self.failure_count >= self.failure_threshold:
                self.state = "OPEN"

            raise e


def with_retry_and_circuit_breaker(retry_config: RetryConfig = None, circuit_breaker: CircuitBreaker = None):
    """Decorator to add retry logic and circuit breaker to functions"""
    if not retry_config:
        retry_config = RetryConfig()

    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            attempt = 0
            last_exception = None

            while attempt < retry_config.max_attempts:
                try:
                    if circuit_breaker:
                        return circuit_breaker.call(func, *args, **kwargs)
                    else:
                        return func(*args, **kwargs)

                except CircuitBreakerError as e:
                    logger.error(
                        f"Circuit breaker preventing call to {func.__name__}: {e}")
                    raise e

                except Exception as e:
                    attempt += 1
                    last_exception = e

                    # Determine if error is retryable
                    if not is_retryable_error(e):
                        logger.error(
                            f"Non-retryable error in {func.__name__}: {e}")
                        raise e

                    if attempt >= retry_config.max_attempts:
                        logger.error(
                            f"Max retry attempts ({retry_config.max_attempts}) exceeded for {func.__name__}")
                        break

                    # Calculate delay with exponential backoff
                    delay = min(
                        retry_config.base_delay *
                        (retry_config.exponential_base ** (attempt - 1)),
                        retry_config.max_delay
                    )

                    # Add jitter to prevent thundering herd
                    if retry_config.jitter:
                        delay += random.uniform(0, delay * 0.1)

                    logger.warning(
                        f"Attempt {attempt} failed for {func.__name__}: {e}. Retrying in {delay:.2f}s...")
                    time.sleep(delay)

            # All retries exhausted
            raise last_exception

        return wrapper
    return decorator


def is_retryable_error(error: Exception) -> bool:
    """Determine if an error should trigger a retry"""
    # Handle GCP-specific errors
    if gcp_exceptions and isinstance(error, gcp_exceptions.GoogleAPIError):
        # Retryable HTTP status codes
        retryable_status_codes = {
            408,  # Request Timeout
            429,  # Too Many Requests (Rate Limiting)
            500,  # Internal Server Error
            502,  # Bad Gateway
            503,  # Service Unavailable
            504,  # Gateway Timeout
        }

        if hasattr(error, 'code') and error.code in retryable_status_codes:
            return True

        # Check error message for known retryable conditions
        error_message = str(error).lower()
        retryable_messages = [
            'timeout',
            'deadline exceeded',
            'temporarily unavailable',
            'rate limit',
            'quota exceeded',
            'service unavailable',
            'connection reset',
            'connection refused'
        ]

        return any(msg in error_message for msg in retryable_messages)

    # Handle generic network/connection errors
    if isinstance(error, (ConnectionError, TimeoutError)):
        return True

    # Handle import errors (when libraries are not available)
    if isinstance(error, ImportError):
        return False

    # Default to non-retryable for unknown errors
    return False


