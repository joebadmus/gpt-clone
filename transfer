    metrics = {
        'individual_emails_found': result.get('individual_emails_found', 0),
        'individual_emails_removed': result.get('individual_emails_removed', 0),
        'groups_preserved': result.get('groups_preserved', 0),
        'service_accounts_preserved': result.get('service_accounts_preserved', 0),
        'total_policy_bindings_before': result.get('policy_comparison', {}).get('current_binding_count', 0),
        'total_policy_bindings_after': result.get('policy_comparison', {}).get('proposed_binding_count', 0),
        'changes_made': result.get('changes_made', False),
        'current_policy_retrieved': result.get('current_policy_retrieved', False)
    }
    action_log['metrics'] = metrics

    # Log with appropriate severity based on action outcome
    if action_taken == 'REMEDIATION_COMPLETED':
        logger.info(f"✅ REMEDIATION SUCCESS", extra={
            'resource_name': resource_name,
            'resource_type': resource_type,
            'action': action_taken,
            'execution_id': execution_id
        })
        # Log monitoring event for successful remediation
        log_remediation_event(resource_name, action_taken,
                              result.get('execution_time_ms'))
        logger.info(f"OVERWATCH_ACTION_SUCCESS: {json.dumps(action_log)}")
    elif action_taken == 'REMEDIATION_FAILED':
        logger.error(f"❌ REMEDIATION FAILED", extra={
            'resource_name': resource_name,
            'resource_type': resource_type,
            'action': action_taken,
            'execution_id': execution_id
        })
        # Log monitoring event for failed remediation
        log_error_event('REMEDIATION_FAILURE', 'iam_remediation',
                        f"Remediation failed for {resource_name}", resource_name)
        logger.error(f"OVERWATCH_ACTION_FAILED: {json.dumps(action_log)}")
    elif action_taken == 'NO_REMEDIATION_NEEDED':
        logger.info(f"ℹ️ NO REMEDIATION NEEDED", extra={
            'resource_name': resource_name,
            'resource_type': resource_type,
            'action': action_taken,
            'execution_id': execution_id
        })
        # Log monitoring event for no remediation needed
        log_remediation_event(resource_name, action_taken,
                              result.get('execution_time_ms'))
        logger.info(f"OVERWATCH_ACTION_SKIPPED: {json.dumps(action_log)}")
    else:
        logger.info(f"OVERWATCH_ACTION: {json.dumps(action_log)}")

    # Log detailed analysis if available
    analysis_details = result.get('analysis_details', {})
    if analysis_details:
        log_analysis_details(execution_id, resource_name, analysis_details)

    # Log policy changes if available
    policy_comparison = result.get('policy_comparison', {})
    if policy_comparison and policy_comparison.get('total_changes', 0) > 0:
        log_policy_changes(execution_id, resource_name, policy_comparison)


