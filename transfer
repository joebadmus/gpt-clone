    def check_timeout():
        """Check if execution is approaching timeout"""
        elapsed_time = (datetime.utcnow() - start_time).total_seconds()
        if elapsed_time > execution_timeout:
            raise TimeoutError(
                f"Function execution exceeded timeout of {execution_timeout}s (elapsed: {elapsed_time:.2f}s)")
        return elapsed_time

    try:
        logger.info(f"🚀 OVERWATCH EXECUTION STARTED", extra={
            'execution_id': execution_id,
            'action': 'FUNCTION_STARTED',
