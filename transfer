def map_iam_role_to_bigquery(iam_role: str) -> str:
    """
    Map IAM role to BigQuery access role.

    Args:
        iam_role: IAM role (roles/bigquery.dataViewer, etc.)

    Returns:
        BigQuery role (READER, WRITER, OWNER)
    """
    role_mapping = {
        'roles/bigquery.dataViewer': 'READER',
        'roles/bigquery.dataEditor': 'WRITER',
        'roles/bigquery.dataOwner': 'OWNER'
    }

    # Extract role from full IAM role path
    role_name = iam_role.split('/')[-1] if '/' in iam_role else iam_role

    # Direct mapping first
    if iam_role in role_mapping:
        return role_mapping[iam_role]

    # Fallback based on role name
    if 'viewer' in role_name.lower() or 'reader' in role_name.lower():
        return 'READER'
    elif 'editor' in role_name.lower() or 'writer' in role_name.lower():
        return 'WRITER'
    elif 'owner' in role_name.lower() or 'admin' in role_name.lower():
        return 'OWNER'
    else:
        logger.warning(
            f"Unknown IAM role for BigQuery mapping: {iam_role}, defaulting to READER")
        return 'READER'


def create_bigquery_access_entry(member: str, role: str):
    """
    Create BigQuery AccessEntry from IAM member and role.

    Args:
        member: IAM member string (e.g., user:email@domain.com)
        role: BigQuery role (READER, WRITER, OWNER)

    Returns:
        BigQuery AccessEntry object or None
    """
    if ':' not in member:
        logger.warning(f"Invalid member format: {member}")
        return None

    member_type, principal = member.split(':', 1)

    try:
        access_entry = bigquery.AccessEntry(None, role, None)

        if member_type == 'user':
            access_entry._properties['userByEmail'] = principal
        elif member_type == 'group':
            access_entry._properties['groupByEmail'] = principal
        elif member_type == 'serviceAccount':
            access_entry._properties['serviceAccountByEmail'] = principal
        elif member_type == 'domain':
            access_entry._properties['domain'] = principal
        else:
            logger.warning(
                f"Unsupported member type for BigQuery: {member_type}")
            return None

        return access_entry

    except Exception as e:
        logger.error(f"Error creating BigQuery access entry for {member}: {e}")
        return None


def create_remediated_policy(current_policy: Dict[str, Any], analysis_result: Dict[str, Any]) -> Dict[str, Any]:
    """
    Create a remediated IAM policy by removing individual emails while preserving groups.

    Args:
        current_policy: Current IAM policy from GCP
        analysis_result: Result from analyze_bindings_for_remediation

    Returns:
        Remediated IAM policy with individual emails removed
    """
    remediated_policy = {
        'bindings': [],
        'etag': current_policy.get('etag', ''),
        'version': current_policy.get('version', 1)
    }

    # Get emails to remove
    emails_to_remove = set()
    for removal_candidate in analysis_result.get('removal_candidates', []):
        emails_to_remove.add(f"user:{removal_candidate['email']}")

    logger.info(
        f"Creating remediated policy - removing {len(emails_to_remove)} individual emails")

    # Process each binding in the current policy
    for binding in current_policy.get('bindings', []):
        role = binding.get('role', '')
        members = binding.get('members', [])

        # Filter out individual emails to be removed
        remediated_members = []
        removed_count = 0

        for member in members:
            if member in emails_to_remove:
                removed_count += 1
                logger.debug(f"Removing {member} from role {role}")
            else:
                remediated_members.append(member)

        # Only keep bindings that have remaining members
        if remediated_members:
            remediated_binding = {
                'role': role,
                'members': remediated_members
            }

            # Preserve conditions if present
            if 'condition' in binding:
                remediated_binding['condition'] = binding['condition']

            remediated_policy['bindings'].append(remediated_binding)
        else:
            logger.info(
                f"Binding for role {role} completely removed (no remaining members)")

    logger.info(
        f"Remediated policy created with {len(remediated_policy['bindings'])} bindings")
    return remediated_policy


def handle_iam_change(log_entry: Dict[str, Any], resource_info: Dict[str, str]) -> Dict[str, Any]:
    """
    Process the IAM policy change and remediate by removing individual email bindings while preserving groups.

    Args:
        log_entry: The cloud audit log entry
        resource_info: Extracted resource information

    Returns:
        Dict containing the remediation action taken and details
    """
    logger.info("Processing IAM policy change for remediation...")

    resource_name = resource_info.get('resource_name', '')
    resource_type = resource_info.get('resource_type', '')

    # Get current IAM policy from GCP
    current_policy = get_current_iam_policy(resource_name, resource_type)
    if not current_policy:
        logger.warning(
            "Could not retrieve current IAM policy - skipping remediation")
        return {
            'action': 'SKIPPED',
            'details': 'Unable to retrieve current IAM policy',
            'individual_emails_found': 0,
            'groups_preserved': 0,
            'changes_made': False
        }

    # Get proposed policy changes from log entry
    policy_changes = resource_info.get('policy_changes', {})
    proposed_bindings = policy_changes.get('bindings', [])

    if not proposed_bindings:
        logger.info("No bindings found in policy changes")
        return {
            'action': 'SKIPPED',
            'details': 'No IAM bindings found to analyze',
            'individual_emails_found': 0,
            'groups_preserved': 0,
            'current_policy_retrieved': True,
            'changes_made': False
        }

    # Analyze proposed bindings for remediation
    analysis_result = analyze_bindings_for_remediation(proposed_bindings)

    # Compare with current policy to identify changes
    policy_comparison = compare_policies(current_policy, proposed_bindings)

    # Check if remediation is needed
    individual_emails_to_remove = analysis_result['individual_emails_to_remove']

    if individual_emails_to_remove == 0:
        logger.info("No individual emails detected - no remediation needed")
        return {
            'action': 'NO_REMEDIATION_NEEDED',
            'details': 'No individual email bindings found to remove',
            'resource_name': resource_name,
            'resource_type': resource_type,
            'individual_emails_found': 0,
            'groups_preserved': analysis_result['groups_to_preserve'],
            'service_accounts_preserved': analysis_result['service_accounts_to_preserve'],
            'policy_comparison': policy_comparison,
            'changes_made': False
        }

    logger.info(
        f"REMEDIATION REQUIRED: {individual_emails_to_remove} individual emails to remove")

    # Create remediated policy by removing individual emails
    remediated_policy = create_remediated_policy(
        current_policy, analysis_result)

    # Apply remediated policy back to GCP resource
    remediation_success = apply_remediated_iam_policy(
        resource_name, resource_type, remediated_policy)

    if remediation_success:
        logger.info(
            f"✅ REMEDIATION SUCCESSFUL: Removed {individual_emails_to_remove} individual email(s) from {resource_name}")
        action = 'REMEDIATION_COMPLETED'
        details = f'Successfully removed {individual_emails_to_remove} individual email bindings while preserving {analysis_result["groups_to_preserve"]} groups and {analysis_result["service_accounts_to_preserve"]} service accounts'
        changes_made = True
    else:
        logger.error(
            f"❌ REMEDIATION FAILED: Could not apply remediated policy to {resource_name}")
        action = 'REMEDIATION_FAILED'
        details = f'Analysis complete but failed to apply remediated policy to {resource_type}'
        changes_made = False

    # Log detailed results
    logger.info(f"Remediation summary:")
    logger.info(f"  - Resource: {resource_name} ({resource_type})")
    logger.info(
        f"  - Individual emails removed: {individual_emails_to_remove if remediation_success else 0}")
    logger.info(
        f"  - Groups preserved: {analysis_result['groups_to_preserve']}")
    logger.info(
        f"  - Service accounts preserved: {analysis_result['service_accounts_to_preserve']}")
    logger.info(f"  - Remediation successful: {remediation_success}")

    return {
        'action': action,
        'details': details,
        'resource_name': resource_name,
        'resource_type': resource_type,
        'current_policy_retrieved': True,
        'current_policy_etag': current_policy.get('etag', ''),
        'individual_emails_found': individual_emails_to_remove,
        'individual_emails_removed': individual_emails_to_remove if remediation_success else 0,
        'groups_preserved': analysis_result['groups_to_preserve'],
        'service_accounts_preserved': analysis_result['service_accounts_to_preserve'],
        'policy_comparison': policy_comparison,
        'analysis_details': analysis_result,
        'remediation_successful': remediation_success,
        'changes_made': changes_made
    }


def compare_policies(current_policy: Dict[str, Any], proposed_bindings: List[Dict[str, Any]]) -> Dict[str, Any]:
    """
    Compare current IAM policy with proposed policy changes.

    Args:
        current_policy: Current IAM policy from GCP
        proposed_bindings: Proposed IAM bindings from audit log

    Returns:
        Dict containing policy comparison analysis
    """
    current_bindings = current_policy.get('bindings', [])

    # Create role->members mapping for easier comparison
    current_role_members = {}
    for binding in current_bindings:
        role = binding.get('role', '')
        members = set(binding.get('members', []))
        current_role_members[role] = members

    proposed_role_members = {}
    for binding in proposed_bindings:
        role = binding.get('role', '')
        members = set(binding.get('members', []))
        proposed_role_members[role] = members

    # Identify changes
    new_bindings = 0
    modified_bindings = 0
    new_members = []
    removed_members = []

    # Check for new or modified role bindings
    for role, proposed_members in proposed_role_members.items():
        if role not in current_role_members:
            # Completely new role binding
            new_bindings += 1
            for member in proposed_members:
                new_members.append(
                    {'role': role, 'member': member, 'change': 'added'})
        else:
            # Existing role - check for member changes
            current_members = current_role_members[role]

            # New members in this role
            added_members = proposed_members - current_members
            if added_members:
                modified_bindings += 1
                for member in added_members:
                    new_members.append(
                        {'role': role, 'member': member, 'change': 'added'})

            # Removed members in this role
            removed_member_set = current_members - proposed_members
            if removed_member_set:
                modified_bindings += 1
                for member in removed_member_set:
                    removed_members.append(
                        {'role': role, 'member': member, 'change': 'removed'})

    # Check for completely removed role bindings
    for role, current_members in current_role_members.items():
        if role not in proposed_role_members:
            for member in current_members:
                removed_members.append(
                    {'role': role, 'member': member, 'change': 'role_removed'})

    return {
        'new_bindings': new_bindings,
        'modified_bindings': modified_bindings,
        'total_changes': len(new_members) + len(removed_members),
        'new_members': new_members,
        'removed_members': removed_members,
        'current_binding_count': len(current_bindings),
        'proposed_binding_count': len(proposed_bindings)
    }


def analyze_bindings_for_remediation(bindings: List[Dict[str, Any]]) -> Dict[str, Any]:
    """
    Analyze IAM bindings to identify which should be removed vs preserved.

    Based on PRD requirements:
    - Remove individual email bindings
    - Preserve groups ending in @googlegroups.com or @[domain].com
    - Preserve service accounts (no false positives)

    Args:
        bindings: List of parsed IAM bindings from policy changes

    Returns:
        Dict containing categorized bindings for remediation
    """
    individual_emails_to_remove = []
    groups_to_preserve = []
    service_accounts_to_preserve = []
    other_principals_to_preserve = []

    for binding in bindings:
        role = binding.get('role', '')
        individual_emails = binding.get('individual_emails', [])
        group_emails = binding.get('group_emails', [])
        service_accounts = binding.get('service_accounts', [])
        other_principals = binding.get('other_principals', [])

        # Analyze individual emails - these should be removed
        for email in individual_emails:
            if should_remove_individual_email(email):
                individual_emails_to_remove.append({
                    'email': email,
                    'role': role,
                    'reason': 'Individual user email detected'
                })
                logger.debug(
                    f"Identified for removal: {email} with role {role}")
            else:
                logger.warning(
                    f"Individual email {email} did not meet removal criteria")

        # Analyze group emails - these should be preserved
        for email in group_emails:
            preservation_result = should_preserve_group_email(email)
            if preservation_result['preserve']:
                groups_to_preserve.append({
                    'email': email,
                    'role': role,
                    'reason': preservation_result['reason']
                })
                logger.debug(
                    f"Group preserved: {email} ({preservation_result['reason']})")
            else:
                logger.warning(
                    f"Group email {email} did not meet preservation criteria: {preservation_result['reason']}")

        # Service accounts - always preserve
        for sa_email in service_accounts:
            service_accounts_to_preserve.append({
                'email': sa_email,
                'role': role,
                'reason': 'Service account - always preserved'
            })
            logger.debug(f"Service account preserved: {sa_email}")

        # Other principals - preserve by default (domains, allUsers, etc.)
        for principal in other_principals:
            other_principals_to_preserve.append({
                'principal': principal,
                'role': role,
                'reason': 'Special principal type - preserved by default'
            })
            logger.debug(f"Other principal preserved: {principal}")

    return {
        'individual_emails_to_remove': len(individual_emails_to_remove),
        'groups_to_preserve': len(groups_to_preserve),
        'service_accounts_to_preserve': len(service_accounts_to_preserve),
        'other_principals_to_preserve': len(other_principals_to_preserve),
        'removal_candidates': individual_emails_to_remove,
        'preserved_groups': groups_to_preserve,
        'preserved_service_accounts': service_accounts_to_preserve,
        'preserved_other': other_principals_to_preserve
    }


def should_remove_individual_email(email: str) -> bool:
    """
    Determine if an individual email should be removed.

    Args:
        email: Individual user email address

    Returns:
        True if the email should be removed
    """
    if not email or '@' not in email:
        logger.warning(f"Invalid email format: {email}")
        return False

    # Basic email validation
    if email.count('@') != 1:
        logger.warning(f"Invalid email format (multiple @): {email}")
        return False

    local_part, domain = email.split('@', 1)

    # Skip obviously invalid emails
    if not local_part or not domain:
        logger.warning(f"Invalid email parts: {email}")
        return False

    # Skip service account emails (they should be categorized as service accounts, but double-check)
    if domain.endswith('.iam.gserviceaccount.com'):
        logger.info(
            f"Service account email detected in individual list: {email}")
        return False

    # Individual user emails should be removed
    logger.debug(f"Individual email approved for removal: {email}")
    return True


def should_preserve_group_email(email: str) -> Dict[str, Any]:
    """
    Determine if a group email should be preserved based on PRD requirements.

    PRD Requirements: Preserve groups ending in @googlegroups.com or @[domain].com

    Args:
        email: Group email address

    Returns:
        Dict with 'preserve' boolean and 'reason' string
    """
    if not email or '@' not in email:
        return {
            'preserve': False,
            'reason': 'Invalid email format'
        }

    # Basic email validation
    if email.count('@') != 1:
        return {
            'preserve': False,
            'reason': 'Invalid email format (multiple @)'
        }

    local_part, domain = email.split('@', 1)

    if not local_part or not domain:
        return {
            'preserve': False,
            'reason': 'Invalid email parts'
        }

    # Check for Google Groups - always preserve
    if domain == 'googlegroups.com':
        return {
            'preserve': True,
            'reason': 'Google Groups email (@googlegroups.com)'
        }

    # Check for domain groups (ending in .com) - preserve based on PRD
    if domain.endswith('.com'):
        return {
            'preserve': True,
            'reason': f'Domain group email (@{domain})'
        }

    # For other group types, be conservative and preserve by default
    # This prevents false positives per PRD requirements
    return {
        'preserve': True,
        'reason': f'Group email preserved (domain: @{domain})'
    }


def log_remediation_action(log_entry: Dict[str, Any], resource_info: Dict[str, str], result: Dict[str, Any]):
    """
    Log comprehensive remediation action taken by Overwatch with full audit trail.

    Args:
        log_entry: The original cloud audit log entry
        resource_info: Extracted resource information  
        result: The remediation result
    """
    start_time = datetime.utcnow()
    execution_id = result.get(
        'execution_id', f"exec_{int(start_time.timestamp())}")

    # Extract key information
    resource_name = resource_info.get('resource_name', '')
    resource_type = resource_info.get('resource_type', '')
    action_taken = result.get('action', '')
    remediation_successful = result.get('remediation_successful', False)

    # Main action log
    action_log = {
        'timestamp': start_time.isoformat() + 'Z',
        'execution_id': execution_id,
        'event_type': 'OVERWATCH_REMEDIATION_ACTION',
        'resource_name': resource_name,
        'resource_type': resource_type,
        'action_taken': action_taken,
        'remediation_successful': remediation_successful,
        'details': result.get('details', ''),
