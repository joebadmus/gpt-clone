    circuit_breaker=_resource_manager_circuit_breaker
)
def get_project_iam_policy(resource_name: str) -> Optional[Dict[str, Any]]:
    """
    Get IAM policy for a GCP project with retry logic and error handling.

    Args:
        resource_name: Project resource name (e.g., projects/project-id)

    Returns:
        Project IAM policy as dict, or None if retrieval fails
    """
    execution_start = time.time()

    try:
        # Extract project ID from resource name
        if not resource_name.startswith('projects/'):
            logger.error(f"Invalid project resource name: {resource_name}")
            return None

        project_id = resource_name.split('/', 1)[1]
        logger.info(f"Retrieving IAM policy for project: {project_id}")

        # Get Resource Manager client
        client = get_resource_manager_client()

        # Get the current policy using project ID directly
        policy = client.get_iam_policy(
            resource=f"projects/{project_id}")

        # Convert to dict format
        policy_dict = {
            'bindings': [],
            'etag': policy.etag.decode('utf-8') if policy.etag else '',
            'version': policy.version
        }

        for binding in policy.bindings:
            binding_dict = {
                'role': binding.role,
                'members': list(binding.members)
            }
            if binding.condition:
                binding_dict['condition'] = {
                    'title': binding.condition.title,
                    'description': binding.condition.description,
                    'expression': binding.condition.expression
                }
            policy_dict['bindings'].append(binding_dict)

        execution_time = (time.time() - execution_start) * 1000
        logger.info(
            f"✅ Successfully retrieved project IAM policy with {len(policy_dict['bindings'])} bindings in {execution_time:.2f}ms")
        return policy_dict

    except CircuitBreakerError as e:
        execution_time = (time.time() - execution_start) * 1000
        logger.error(
            f"❌ Circuit breaker prevented project IAM policy retrieval after {execution_time:.2f}ms: {e}")
        return None
    except gcp_exceptions.GoogleAPIError as e:
        execution_time = (time.time() - execution_start) * 1000
        logger.error(
            f"❌ Google API error retrieving project IAM policy after {execution_time:.2f}ms: {e}")
        # Log additional error details for debugging
        if hasattr(e, 'code'):
            logger.error(f"   Error code: {e.code}")
        if hasattr(e, 'details'):
            logger.error(f"   Error details: {e.details}")
        return None
    except Exception as e:
        execution_time = (time.time() - execution_start) * 1000
        logger.error(
            f"❌ Unexpected error retrieving project IAM policy after {execution_time:.2f}ms: {e}")
        return None


@with_retry_and_circuit_breaker(
    retry_config=get_optimized_retry_config(),
    circuit_breaker=_bigquery_circuit_breaker
)
def get_dataset_iam_policy(resource_name: str) -> Optional[Dict[str, Any]]:
    """
    Get IAM policy for a BigQuery dataset with retry logic and error handling.

    Args:
        resource_name: Dataset resource name (e.g., projects/project-id/datasets/dataset-id)

    Returns:
        Dataset IAM policy as dict, or None if retrieval fails
    """
    execution_start = time.time()

    try:
        # Parse resource name to extract project and dataset IDs
        parts = resource_name.split('/')
        if len(parts) < 4 or parts[0] != 'projects' or parts[2] != 'datasets':
            logger.error(f"Invalid dataset resource name: {resource_name}")
            return None

        project_id = parts[1]
        dataset_id = parts[3]
        logger.info(
            f"Retrieving IAM policy for BigQuery dataset: {project_id}.{dataset_id}")

        # Get BigQuery client
        client = get_bigquery_client()

        # Get dataset reference
        dataset_ref = client.dataset(dataset_id, project=project_id)
        dataset = client.get_dataset(dataset_ref)

        # Get access entries (BigQuery's version of IAM bindings)
        policy_dict = {
            'bindings': [],
            'etag': '',  # BigQuery doesn't use etags for access control
            'version': 1
        }

        # Convert BigQuery access entries to IAM binding format
        role_members_map = {}
        for access_entry in dataset.access_entries:
            role = map_bigquery_role_to_iam(access_entry.role)
            member = map_bigquery_entity_to_iam_member(access_entry)
            if role and member:
                if role not in role_members_map:
                    role_members_map[role] = []
                role_members_map[role].append(member)

        # Convert to binding format
        for role, members in role_members_map.items():
            policy_dict['bindings'].append({
                'role': role,
                'members': members
            })

        execution_time = (time.time() - execution_start) * 1000
        logger.info(
            f"✅ Successfully retrieved dataset IAM policy with {len(policy_dict['bindings'])} bindings in {execution_time:.2f}ms")
        return policy_dict

    except CircuitBreakerError as e:
        execution_time = (time.time() - execution_start) * 1000
        logger.error(
            f"❌ Circuit breaker prevented dataset IAM policy retrieval after {execution_time:.2f}ms: {e}")
        return None
    except Exception as e:
        execution_time = (time.time() - execution_start) * 1000
        logger.error(
            f"❌ Error retrieving dataset IAM policy after {execution_time:.2f}ms: {e}")
        # Log additional context for BigQuery errors
        if 'NotFound' in str(e):
            logger.error(f"   Dataset may not exist: {resource_name}")
        elif 'Forbidden' in str(e):
            logger.error(
                f"   Insufficient permissions to access dataset: {resource_name}")
        return None


def get_table_iam_policy(resource_name: str) -> Optional[Dict[str, Any]]:
    """
    Get IAM policy for a BigQuery table.

    Args:
        resource_name: Table resource name (e.g., projects/project-id/datasets/dataset-id/tables/table-id)

    Returns:
        Table IAM policy as dict, or None if retrieval fails
    """
    try:
        # Parse resource name to extract project, dataset, and table IDs
        parts = resource_name.split('/')
        if len(parts) < 6 or parts[0] != 'projects' or parts[2] != 'datasets' or parts[4] != 'tables':
            logger.error(f"Invalid table resource name: {resource_name}")
            return None

        project_id = parts[1]
        dataset_id = parts[3]
        table_id = parts[5]

        # Get BigQuery client
        client = get_bigquery_client()

        # Get table reference
        table_ref = client.dataset(
            dataset_id, project=project_id).table(table_id)
        table = client.get_table(table_ref)

        # Note: BigQuery tables inherit access from datasets by default
        # Table-level access control is limited compared to dataset-level
        logger.info(
            f"Retrieved table reference for {table_id} (table-level IAM is limited in BigQuery)")

        # Return empty policy as tables typically inherit dataset permissions
        return {
            'bindings': [],
            'etag': '',
            'version': 1,
            'note': 'BigQuery tables typically inherit permissions from dataset'
        }

    except Exception as e:
        logger.error(f"Error retrieving table IAM policy: {e}")
        return None


def map_bigquery_role_to_iam(bq_role: str) -> str:
    """
    Map BigQuery access role to equivalent IAM role.

    Args:
        bq_role: BigQuery role (READER, WRITER, OWNER)

    Returns:
        Equivalent IAM role
    """
    role_mapping = {
        'READER': 'roles/bigquery.dataViewer',
        'WRITER': 'roles/bigquery.dataEditor',
        'OWNER': 'roles/bigquery.dataOwner'
    }
    return role_mapping.get(bq_role, f'roles/bigquery.{bq_role.lower()}')


def map_bigquery_entity_to_iam_member(access_entry) -> Optional[str]:
    """
    Map BigQuery access entry entity to IAM member format.

    Args:
        access_entry: BigQuery AccessEntry object

    Returns:
        IAM member string (e.g., user:email@domain.com)
    """
    if access_entry.user_by_email:
        return f"user:{access_entry.user_by_email}"
    elif access_entry.group_by_email:
        return f"group:{access_entry.group_by_email}"
    elif access_entry.service_account_by_email:
        return f"serviceAccount:{access_entry.service_account_by_email}"
    elif access_entry.domain:
        return f"domain:{access_entry.domain}"
    else:
        logger.warning(f"Unknown BigQuery access entry type: {access_entry}")
        return None


def process_iam_change(data: Dict[str, Any], context: Any) -> str:
