    def format(self, record):
        log_entry = {
            'timestamp': datetime.utcnow().isoformat() + 'Z',
            'severity': record.levelname,
            'component': 'overwatch-iam-processor',
            'message': record.getMessage(),
            'function_name': record.funcName,
            'line_number': record.lineno,
            'project_id': PROJECT_ID
        }

        # Add extra fields if present
        if hasattr(record, 'resource_name'):
            log_entry['resource_name'] = record.resource_name
        if hasattr(record, 'resource_type'):
            log_entry['resource_type'] = record.resource_type
        if hasattr(record, 'action'):
            log_entry['action'] = record.action
        if hasattr(record, 'execution_id'):
            log_entry['execution_id'] = record.execution_id
        if hasattr(record, 'duration_ms'):
            log_entry['duration_ms'] = record.duration_ms
        if hasattr(record, 'execution_time_ms'):
            log_entry['execution_time_ms'] = record.execution_time_ms
        if hasattr(record, 'event_type'):
            log_entry['event_type'] = record.event_type
        if hasattr(record, 'operation'):
            log_entry['operation'] = record.operation
        if hasattr(record, 'error_type'):
            log_entry['error_type'] = record.error_type
        if hasattr(record, 'action_taken'):
            log_entry['action_taken'] = record.action_taken

        return json.dumps(log_entry)


